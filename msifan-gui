#!/usr/bin/env bash
# msifan-gui launcher — corre GUI como usuario normal (no root)
# Los comandos que necesitan root los ejecuta internamente con sudo.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Localiza el directorio que CONTIENE el paquete `msifan_gui`:
#  · ejecucion desde el repo  -> junto al launcher
#  · instalado                -> /usr/local/lib/msifan-gui
if [[ -d "$SCRIPT_DIR/msifan_gui" ]]; then
    PKG_ROOT="$SCRIPT_DIR"
else
    PKG_ROOT="/usr/local/lib/msifan-gui"
fi

export GDK_BACKEND=wayland
export GSK_RENDERER=gl        # evita conflicto GTK4-Vulkan + Hyprland/Intel
# Si usas NVIDIA como GPU principal en Hyprland:
# export __NV_PRIME_RENDER_OFFLOAD=1
# export __GLX_VENDOR_LIBRARY_NAME=nvidia
export PYTHONPATH="$PKG_ROOT${PYTHONPATH:+:$PYTHONPATH}"
exec python3 -m msifan_gui "$@"
